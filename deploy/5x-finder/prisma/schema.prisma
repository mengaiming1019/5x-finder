generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Stock {
  id          String   @id @default(cuid())
  ticker      String   @unique
  name        String
  sector      String
  subSector   String
  marketCap   String
  price       String
  description String
  logoUrl     String?
  website     String?

  revenueGrowth      Int
  marketOpportunity  Int
  competitiveMoat    Int
  profitabilityPath  Int
  valuation          Int

  executionCapabilities Int
  innovationCulture     Int
  fundingStrength       Int
  customerStickiness    Int
  monetizationModel     Int

  fiveXScore         Int

  // Financial metrics
  peRatio     Float?
  pegRatio    Float?
  evSales     Float?
  evEbitda    Float?

  aiAnalysis    String?
  lastAnalyzed  DateTime?

  latestNews    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FactorWeight {
  id                String @id @default(cuid())
  revenueGrowth     Float  @default(0.15)
  marketOpportunity Float  @default(0.15)
  competitiveMoat   Float  @default(0.15)
  profitabilityPath Float  @default(0.10)
  valuation         Float  @default(0.10)
  executionCapabilities Float @default(0.10)
  innovationCulture     Float @default(0.08)
  fundingStrength       Float @default(0.07)
  customerStickiness    Float @default(0.05)
  monetizationModel     Float @default(0.05)
  updatedAt         DateTime @updatedAt
}
