generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Stock {
  id          String   @id @default(cuid())
  ticker      String   @unique
  name        String
  sector      String
  subSector   String
  marketCap   String
  price       String
  description String
  logoUrl     String?
  website     String?

  // Quantitative Factor Scores (0-100)
  revenueGrowth      Int
  marketOpportunity  Int
  competitiveMoat    Int
  profitabilityPath  Int
  valuation          Int
  industryKnowledge  Int

  // Qualitative Factor Scores (0-100)
  executionCapabilities Int
  innovationCulture     Int
  fundingStrength       Int
  customerStickiness    Int
  monetizationModel     Int

  // Composite
  fiveXScore         Int

  // AI Analysis
  aiAnalysis    String?
  lastAnalyzed  DateTime?

  // News (JSON string)
  latestNews    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FactorWeight {
  id                String @id @default(cuid())
  // Quantitative weights
  revenueGrowth     Float  @default(0.12)
  marketOpportunity Float  @default(0.12)
  competitiveMoat   Float  @default(0.10)
  profitabilityPath Float  @default(0.10)
  valuation         Float  @default(0.08)
  industryKnowledge Float  @default(0.08)
  // Qualitative weights
  executionCapabilities Float @default(0.10)
  innovationCulture     Float @default(0.08)
  fundingStrength       Float @default(0.08)
  customerStickiness    Float @default(0.08)
  monetizationModel     Float @default(0.06)
  updatedAt         DateTime @updatedAt
}
